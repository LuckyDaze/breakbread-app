# ---- Helper functions ----

def api_request(endpoint, method="GET", data=None, need_auth=True):

headers = {}

if need_auth and st.session_state.token:

headers["Authorization"] = f"Bearer {st.session_state.token}"

if method == "GET":

resp = requests.get(f"{API_URL}{endpoint}", headers=headers)

else:

resp = requests.post(f"{API_URL}{endpoint}", json=data, headers=headers)

if resp.status_code == 401:

st.session_state.token = None

st.session_state.user_id = None

st.error("Session expired. Please log in again.")

st.rerun()

return resp.json() if resp.status_code == 200 else None



def login(username, password):

resp = api_request("/login", method="POST", data={"username": username, "password": password}, need_auth=False)

if resp and "access_token" in resp:

st.session_state.token = resp["access_token"]

# decode JWT to get user_id (or store from response)

# For simplicity, we'll call /me endpoint (we can add one)

me = api_request("/me", need_auth=True) # we'll add a /me endpoint later

if me:

st.session_state.user_id = me["user_id"]

return True

return False



def register(app_id, email, password, full_name):

resp = api_request("/register", method="POST", data={

"app_id": app_id, "email": email, "password": password, "full_name": full_name

}, need_auth=False)

if resp and "access_token" in resp:

st.session_state.token = resp["access_token"]

return True

return False



